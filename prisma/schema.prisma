generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ USERS & AUTH ============

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String?
  role          String    @default("affiliate") // "admin" | "affiliate"
  avatarUrl     String?
  phone         String?
  company       String?
  status        String    @default("active") // "active" | "inactive" | "suspended"
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  affiliate     Affiliate?
  sessions      Session[]
  activities    Activity[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ============ AFFILIATES ============

model Affiliate {
  id              String   @id @default(cuid())
  userId          String   @unique
  referralCode    String   @unique
  tier            String   @default("standard") // "standard" | "pro" | "elite"
  commissionRate  Float    @default(10) // percentage
  totalEarnings   Float    @default(0)
  totalReferrals  Int      @default(0)
  totalConversions Int     @default(0)
  balance         Float    @default(0)
  bankName        String?
  bankAccount     String?
  bankIfsc        String?
  upiId           String?
  payoutMethod    String   @default("bank") // "bank" | "upi" | "paypal"
  payoutEmail     String?  // for PayPal
  status          String   @default("active") // "active" | "pending" | "inactive" | "suspended"
  joinedAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  links           Link[]
  referrals       Referral[]
  commissions     Commission[]
  payouts         Payout[]
  invoices        Invoice[]

  @@index([userId])
  @@index([referralCode])
  @@index([status])
}

// ============ PROGRAMS ============

model Program {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?
  commissionType  String   @default("percentage") // "percentage" | "fixed"
  commissionValue Float    @default(10) // percentage or fixed amount
  minPayout       Float    @default(50)
  cookieDuration  Int      @default(30) // days
  isActive        Boolean  @default(true)
  startDate       DateTime?
  endDate         DateTime?
  imageUrl        String?
  landingPageUrl  String?
  terms           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  links           Link[]
  commissions     Commission[]
  referrals       Referral[]

  @@index([slug])
  @@index([isActive])
}

// ============ TRACKING LINKS ============

model Link {
  id          String   @id @default(cuid())
  affiliateId String
  programId   String
  code        String   @unique
  url         String   // the full tracking URL
  clicks      Int      @default(0)
  conversions Int      @default(0)
  isActive    Boolean  @default(true)
  label       String?  // custom label for the link
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  affiliate   Affiliate  @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  program     Program    @relation(fields: [programId], references: [id], onDelete: Cascade)
  referrals   Referral[]

  @@index([affiliateId])
  @@index([programId])
  @@index([code])
}

// ============ REFERRALS ============

model Referral {
  id           String   @id @default(cuid())
  affiliateId  String
  programId    String
  linkId       String?
  referralCode String
  visitorEmail String?
  visitorName  String?
  visitorIp    String?
  source       String?  // "social" | "email" | "website" | "direct"
  status       String   @default("clicked") // "clicked" | "registered" | "converted" | "cancelled"
  convertedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  affiliate    Affiliate   @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  program      Program     @relation(fields: [programId], references: [id], onDelete: Cascade)
  link         Link?       @relation(fields: [linkId], references: [id], onDelete: SetNull)
  commissions  Commission[]

  @@index([affiliateId])
  @@index([programId])
  @@index([status])
  @@index([createdAt])
}

// ============ COMMISSIONS ============

model Commission {
  id          String   @id @default(cuid())
  affiliateId String
  programId   String
  referralId  String?
  amount      Float
  rate        Float    // the commission rate at time of earning
  type        String   @default("referral") // "referral" | "bonus" | "adjustment"
  status      String   @default("pending") // "pending" | "approved" | "paid" | "cancelled" | "refunded"
  payoutId    String?  // linked to payout when paid
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  affiliate   Affiliate  @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  program     Program    @relation(fields: [programId], references: [id], onDelete: Cascade)
  referral    Referral?  @relation(fields: [referralId], references: [id], onDelete: SetNull)
  payout      Payout?    @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@index([affiliateId])
  @@index([programId])
  @@index([status])
  @@index([createdAt])
}

// ============ PAYOUTS ============

model Payout {
  id           String   @id @default(cuid())
  affiliateId  String
  amount       Float
  method       String   @default("bank") // "bank" | "upi" | "paypal"
  status       String   @default("pending") // "pending" | "processing" | "completed" | "failed" | "cancelled"
  reference    String?  // transaction reference
  notes        String?
  processedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  affiliate    Affiliate    @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  commissions  Commission[]
  invoice      Invoice?

  @@index([affiliateId])
  @@index([status])
  @@index([createdAt])
}

// ============ INVOICES ============ =

model Invoice {
  id          String   @id @default(cuid())
  payoutId    String   @unique
  affiliateId String
  amount      Float
  invoiceNo   String   @unique
  status      String   @default("generated") // "generated" | "sent" | "paid"
  pdfUrl      String?
  issuedAt    DateTime @default(now())
  dueDate     DateTime?
  paidAt      DateTime?

  payout      Payout     @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  affiliate   Affiliate  @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([invoiceNo])
}

// ============ ACTIVITY LOG ============

model Activity {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?  // "affiliate" | "program" | "referral" | "commission" | "payout"
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([entity, entityId])
}

// ============ SETTINGS ============

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  updatedAt DateTime @updatedAt

  @@index([key])
}
